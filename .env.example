DATABASE_URL=file:./rss-parser.db
PAYLOAD_SECRET=YOUR_SECRET_HERE
PAYLOAD_PUBLIC_SERVER_URL=http://localhost:3000

SMTP_HOST=
SMTP_USER=
SMTP_PASS=
EMAIL_FROM=

# Optional: route adapter traffic (Instagram fetches) through a residential
# HTTP proxy so Instagram doesn't see a datacenter IP. Format:
# http://user:password@host:port, with country/session targeting in the creds.
#
# Sticky sessions: include the literal token {session} anywhere in the URL and
# it is substituted with a fresh id per fetch, so the cookie-prime and the
# profile request share one exit IP (needed for the guest-session handshake).
# With no {session} token, traffic just rotates per request. The placeholder
# works with any session-capable HTTP proxy.
#
# Decodo residential (https://decodo.com) — targeting/session go in the username:
# OUTBOUND_PROXY_URL=http://user-<DECODO_USERNAME>-country-us-session-{session}:<DECODO_PASSWORD>@gate.decodo.com:7000
OUTBOUND_PROXY_URL=

# Optional: Hetzner Object Storage (S3-compatible) for feed item images. When
# set, each item's image is downloaded once and served from the bucket; when
# unset, feeds serve the platform's signed CDN URLs directly (expire after a
# few days and are origin-restricted). Bucket must allow public read.
S3_ENDPOINT=            # e.g. https://fsn1.your-objectstorage.com
S3_REGION=              # e.g. fsn1
S3_BUCKET=
S3_ACCESS_KEY_ID=
S3_SECRET_ACCESS_KEY=